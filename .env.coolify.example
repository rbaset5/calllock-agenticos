# Coolify deploy configuration
# Copy to .env.coolify and fill in your values
#
# To get these values:
# 1. COOLIFY_HOST: your Coolify dashboard URL (e.g. http://89.167.116.18:8000)
# 2. COOLIFY_API_TOKEN: Settings > Keys & Tokens > API Tokens > create with Deploy permission
# 3. COOLIFY_APP_UUID: open your app in Coolify, UUID is in the URL or General settings

COOLIFY_HOST=http://89.167.116.18:8000
COOLIFY_API_TOKEN=
COOLIFY_APP_UUID=

        "worker_reliability": {
          "runbook_id": "rb-worker-reliability",
          "title": "Worker Reliability Response",
          "steps": [
            {
              "title": "Review the latest failed jobs and verification findings.",
              "required": true,
              "parallel_group": "triage"
            },
            {
              "title": "Confirm whether the issue is isolated to one worker or cross-worker.",
              "required": true,
              "parallel_group": "triage"
            },
            {
              "title": "Decide whether execution can safely resume or requires rollback.",
              "required": false,
              "depends_on": [1, 2]
            }
          ],
          "completion_policy": {
            "required_workflow_statuses": ["closed"],
            "notes": "All worker reliability checklist steps must be completed before closing."
          },
          "approval_policy": {
            "required_workflow_statuses": ["closed"],
            "notes": "Closing a worker reliability incident requires operator approval."
          }
        },
        "scheduler_health": {
          "runbook_id": "rb-scheduler-health",
          "title": "Scheduler Health Recovery",
          "steps": [
            {
              "title": "Inspect stale claims and pending backlog.",
              "required": true
            },
            {
              "title": "Sweep or override stuck scheduler claims if needed.",
              "required": true,
              "depends_on": [1]
            },
            {
              "title": "Validate retention and eval schedulers are progressing again.",
              "required": true,
              "depends_on": [2]
            }
          ],
          "completion_policy": {
            "required_workflow_statuses": []
          },
          "approval_policy": {
            "required_workflow_statuses": []
          }
        }
